generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // تم نقل url إلى prisma.config.ts
}

model Article {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(200)
  content     String   @db.Text
  category    Category @default(Tech)
  image       String?
  author      String?  @default("Dr. Emily Walker")
  date        DateTime @default(now())
  readingTime String?  @default("10 min read")
  likes       String?  @default("24.5k")
  views       String?  @default("50k")
  comments    Int?     @default(206)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("articles")
}

enum Category {
  Tech
  News
  AI
  Tips
  Other
}
